@model IEnumerable<FSP.AttendanceClock.Core.Entities.Attendance>

@{
    ViewData["Title"] = "Administration - History";
}

<div class="dashboard-container" style="max-width: 1000px;">
    <div class="header glass-effect mb-4 p-4 rounded d-flex justify-content-between align-items-center">
        <div>
            <h1>Administration Panel</h1>
            <p class="text-muted">Complete attendance records</p>
        </div>
        <div>
            <a asp-action="AuditLog" class="btn btn-info me-2 text-white"><i class="bi bi-shield-lock"></i> Audit Log</a>
            <a asp-action="HoursReport" class="btn btn-success me-2"><i class="bi bi-clock-history"></i> Hours Report</a>
            <a asp-action="ExportToExcel" class="btn btn-warning me-2"><i class="bi bi-file-earmark-spreadsheet"></i> Export Excel</a>
            <a asp-action="Users" class="btn btn-primary">Manage Users</a>
        </div>
    </div>

    <div class="history-section glass-effect p-4 rounded">
        <h3>All Records</h3>
        <table class="table table-hover mt-3">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Type</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="fw-bold">@item.User.Username</span></td>
                        <td>@item.Timestamp.ToLocalTime().ToShortDateString()</td>
                        <td>@item.Timestamp.ToLocalTime().ToShortTimeString()</td>
                        <td>
                            @if (item.Type == FSP.AttendanceClock.Core.Entities.AttendanceType.CheckIn)
                            {
                                <span class="badge bg-success">Check In</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Check Out</span>
                            }
                        </td>
                        <td>
                             <a asp-controller="Attendance" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
