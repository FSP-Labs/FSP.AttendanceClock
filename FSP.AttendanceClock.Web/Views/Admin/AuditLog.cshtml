@model IEnumerable<FSP.AttendanceClock.Core.Entities.SystemLog>

@{
    ViewData["Title"] = "Auditoría Universal";
}

<div class="dashboard-container" style="max-width: 1200px;">
    <div class="header glass-effect mb-4 p-4 rounded d-flex justify-content-between align-items-center">
        <div>
            <h1>Auditoría Completa</h1>
            <p class="text-muted">Registro de todas las acciones del sistema (Fichajes, Ediciones, Usuarios)</p>
        </div>
        <div>
            <a asp-action="ExportAuditLog" class="btn btn-warning me-2"><i class="bi bi-file-earmark-spreadsheet"></i> Exportar Auditoría</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>
    </div>

    <div class="glass-effect p-4 rounded">
        <table class="table table-hover table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Fecha</th>
                    <th>Usuario (Actor)</th>
                    <th>Acción</th>
                    <th>Detalles</th>
                    <th>IP</th>
                    <th>User-Agent</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>
                            @{
                                var spanishZone = TimeZoneInfo.FindSystemTimeZoneById("Central European Standard Time");
                                var spanishTime = TimeZoneInfo.ConvertTimeFromUtc(log.Timestamp, spanishZone);
                            }
                            @spanishTime.ToString("g")
                        </td>
                        <td>@log.Username</td>
                        <td>
                            @if(log.Action.Contains("CheckIn") || log.Action.Contains("Entrada")) { <span class="badge bg-success">Entrada</span> }
                            else if(log.Action.Contains("CheckOut") || log.Action.Contains("Salida")) { <span class="badge bg-danger">Salida</span> }
                            else if(log.Action.Contains("Edit") || log.Action.Contains("Edicion") || log.Action.Contains("EdicionFichaje") ) { <span class="badge bg-warning text-dark">Edición</span> }
                            else if(log.Action.Contains("User") || log.Action.Contains("Usuario")) { <span class="badge bg-info text-dark">Usuario</span> }
                            else { <span class="badge bg-secondary">@log.Action</span> }
                        </td>
                        <td>@log.Details</td>
                        <td>@log.IpAddress</td>
                        <td style="max-width:300px; overflow:auto; word-break:break-all;">@log.UserAgent</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
