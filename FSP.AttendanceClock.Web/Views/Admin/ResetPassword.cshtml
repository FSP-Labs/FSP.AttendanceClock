@model FSP.AttendanceClock.Core.Entities.User

@{
    ViewData["Title"] = "Reset Password";
}

<div class="card glass-effect" style="max-width: 500px; margin: auto;">
    <div class="card-header">
        <h2>Reset Password for @Model.Username</h2>
    </div>
    <div class="card-body">
        <form asp-action="ResetPassword" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="text" name="newPassword" class="form-control" required />
                <small class="text-muted">Enter the new password for this employee.</small>
            </div>

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-warning">Reset Password</button>
                <a asp-action="Users" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
