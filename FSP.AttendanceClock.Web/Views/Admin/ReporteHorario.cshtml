@{
    ViewData["Title"] = "Hours Report";
}

<h2>Hours Report</h2>

<form method="get" asp-action="HoursReport" class="row g-3">
    <div class="col-md-4">
        <label class="form-label">User</label>
        <select name="userId" class="form-select">
            <option value="">Select a user</option>
            @foreach (var u in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Users)
            {
                @if (u.Value == ViewBag.SelectedUserId?.ToString())
                {
                    <option value="@u.Value" selected>@u.Text</option>
                }
                else
                {
                    <option value="@u.Value">@u.Text</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">From</label>
        <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
    </div>
    <div class="col-md-3">
        <label class="form-label">To</label>
        <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
    </div>
    <div class="col-md-2 align-self-end">
        <button type="submit" class="btn btn-primary">Generate</button>
    </div>
</form>

<hr />

@if (ViewBag.AttendanceRecords != null && ViewBag.AttendanceRecords.Count > 0)
{
    <div class="mb-3">
        <a asp-action="ExportHoursReport" asp-route-userId="@ViewBag.SelectedUserId" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" class="btn btn-success">
            <i class="bi bi-file-earmark-spreadsheet"></i> Export to Excel
        </a>
    </div>

    <h3>History - @ViewBag.Username</h3>

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card card-body bg-light">
                <strong>Ordinary hours:</strong> @String.Format("{0:0.##}", (double?)ViewBag.TotalOrdinaryHours ?? 0) h
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-body bg-light">
                <strong>Extra hours:</strong> @String.Format("{0:0.##}", (double?)ViewBag.TotalExtraHours ?? 0) h
            </div>
        </div>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Check-In Time</th>
                <th>Check-Out Time</th>
                <th>Hours Worked</th>
                <th>Ordinary Hours (&lt;= 8h)</th>
                <th>Extra Hours</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in ViewBag.AttendanceRecords)
            {
                <tr>
                    <td>@record.Date</td>
                    <td>@record.CheckInTime</td>
                    <td>@record.CheckOutTime</td>
                    <td>@String.Format("{0:0.##}", ((TimeSpan)record.WorkedHours).TotalHours)</td>
                    <td>@String.Format("{0:0.##}", ((TimeSpan)record.OrdinaryHours).TotalHours)</td>
                    <td>@String.Format("{0:0.##}", ((TimeSpan)record.ExtraHours).TotalHours)</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (ViewBag.SelectedUserId != null && (ViewBag.AttendanceRecords == null || ViewBag.AttendanceRecords.Count == 0))
{
    <p>No records found for the selected user in this date range.</p>
}
