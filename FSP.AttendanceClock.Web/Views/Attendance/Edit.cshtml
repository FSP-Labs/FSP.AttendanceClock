@model FSP.AttendanceClock.Core.Entities.Attendance

@{
    ViewData["Title"] = "Editar Fichaje";
}

<div class="card glass-effect" style="max-width: 600px; margin: auto;">
    <div class="card-header">
        <h2>Editar Fichaje</h2>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label">Hora actual registrada</label>
                <input type="text" class="form-control" value="@Model.Timestamp.ToLocalTime().ToString("g")" disabled />
            </div>

            <div class="mb-3">
                <label for="newTimestamp" class="form-label">Nueva Hora</label>
                <input type="datetime-local" name="newTimestamp" class="form-control" value="@Model.Timestamp.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")" required />
            </div>

            <div class="mb-3">
                <label for="reason" class="form-label">Motivo de la corrección</label>
                <textarea name="reason" class="form-control" rows="3" required placeholder="Por favor explica por qué cambias la hora..."></textarea>
                <small class="text-muted">Es obligatorio indicar un motivo.</small>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-warning">Guardar Cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
